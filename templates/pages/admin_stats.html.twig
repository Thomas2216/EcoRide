{% extends 'base.html.twig' %}

{% block title %}Statistiques des visites — Admin{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">Statistiques des visites (MongoDB)</h1>
    <p class="text-muted">50 dernières consultations de la page covoiturages, triées par date décroissante.</p>

    {% if stats is empty %}
        <div class="alert alert-info">Aucune statistique enregistrée pour le moment.</div>
    {% else %}
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Date et heure</th>
                    <th>Nombre de covoiturages affichés</th>
                    <th>IP utilisateur</th>
                </tr>
            </thead>
            <tbody>
                {% for stat in stats %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td>{{ stat.date|date('d/m/Y H:i:s') }}</td>
                        <td>{{ stat.nombreCovoiturages }}</td>
                        <td>{{ stat.ipUtilisateur }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <a href="{{ path('app_admin') }}" class="btn btn-secondary mt-3">Retour au tableau de bord</a>
</div>
{% endblock %}
